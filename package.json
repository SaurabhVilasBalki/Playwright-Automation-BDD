{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Best-practice Playwright TypeScript automation framework for UI, API, accessibility, and CI testing.",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf test-results playwright-report allure-results coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api --project=api",
    "test:a11y": "playwright test tests/accessibility",
    "test:data": "playwright test tests/api/todos.csv.api.spec.ts --project=api",
    "bdd:gen": "bddgen",
    "test:bdd": "npm run bdd:gen && playwright test --project=bdd-chromium",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "install:browsers": "playwright install --with-deps",
    "ci": "npm run bdd:gen && npm run typecheck && npm run lint && playwright test"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.55.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "allure-playwright": "^3.10.0",
    "axe-core": "^4.12.1",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-playwright": "^2.10.4",
    "playwright-bdd": "^8.5.1",
    "playwright-core": "^1.55.1",
    "prettier": "^3.8.4",
    "rimraf": "^5.0.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  }
}
